<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xmlns:p="http://www.springframework.org/schema/p"
       xmlns:context="http://www.springframework.org/schema/context"
       xmlns:mvc="http://www.springframework.org/schema/mvc"
       xsi:schemaLocation="
           http://www.springframework.org/schema/beans
               http://www.springframework.org/schema/beans/spring-beans-4.0.xsd
           http://www.springframework.org/schema/context
               http://www.springframework.org/schema/context/spring-context-4.0.xsd
           http://www.springframework.org/schema/mvc
               http://www.springframework.org/schema/mvc/spring-mvc-4.0.xsd">

    <!--
        [mvc:annotation-driven 이란?]
        @Controller, @RequestMapping, @Valid, @ModelAttribute 등
        Spring MVC 어노테이션이 동작하도록 필요한 빈을 자동으로 등록합니다.
        아래 기능을 한 번에 활성화합니다:
          ① RequestMappingHandlerAdapter / RequestMappingHandlerMapping 자동 구성
          ② Bean Validation (@Valid) 자동 활성화 (Hibernate Validator가 classpath에 있으면)
          ③ JSON/XML 변환기(MessageConverter) 등록
          ④ ConversionService 등록
    -->
    <mvc:annotation-driven/>

    <!-- egovframework.asset 패키지의 @Controller 클래스 자동 탐색 -->
    <context:component-scan base-package="egovframework.asset">
        <context:include-filter type="annotation" expression="org.springframework.stereotype.Controller"/>
        <context:exclude-filter type="annotation" expression="org.springframework.stereotype.Service"/>
        <context:exclude-filter type="annotation" expression="org.springframework.stereotype.Repository"/>
    </context:component-scan>

    <!--
        [인터셉터 설정]
        mvc:interceptors 를 사용하면 특정 URL 패턴에만 인터셉터를 적용할 수 있습니다.
        LocaleChangeInterceptor: URL 파라미터 ?language=ko 로 언어 변경 가능
    -->
    <mvc:interceptors>
        <mvc:interceptor>
            <mvc:mapping path="/**"/>
            <bean class="org.springframework.web.servlet.i18n.LocaleChangeInterceptor">
                <property name="paramName" value="language"/>
            </bean>
        </mvc:interceptor>
    </mvc:interceptors>

    <!-- 세션 기반 로케일 저장 (브라우저 세션 동안 선택한 언어 유지) -->
    <bean id="localeResolver" class="org.springframework.web.servlet.i18n.SessionLocaleResolver"/>

    <!--
        [예외 발생 시 이동할 뷰 매핑]
        SimpleMappingExceptionResolver: 예외 종류에 따라 보여줄 JSP를 지정합니다.
        뷰 이름 "cmmn/egovError" → ViewResolver가
        /WEB-INF/jsp/egovframework/asset/cmmn/egovError.jsp 로 변환합니다.
    -->
    <bean class="org.springframework.web.servlet.handler.SimpleMappingExceptionResolver">
        <property name="defaultErrorView" value="cmmn/egovError"/>
        <property name="exceptionMappings">
            <props>
                <prop key="org.springframework.dao.DataAccessException">cmmn/dataAccessFailure</prop>
                <prop key="org.springframework.transaction.TransactionException">cmmn/transactionFailure</prop>
                <prop key="org.egovframe.rte.fdl.cmmn.exception.EgovBizException">cmmn/egovError</prop>
            </props>
        </property>
    </bean>

    <!--
        [뷰 리졸버 (ViewResolver)]
        컨트롤러에서 return "user/login" 하면:
          prefix + "user/login" + suffix
          = /WEB-INF/jsp/egovframework/asset/ + user/login + .jsp
          = /WEB-INF/jsp/egovframework/asset/user/login.jsp
    -->
    <bean class="org.springframework.web.servlet.view.UrlBasedViewResolver"
          p:order="1"
          p:viewClass="org.springframework.web.servlet.view.JstlView"
          p:prefix="/WEB-INF/jsp/egovframework/asset/"
          p:suffix=".jsp"/>

</beans>
